---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;

const PHOTOS_BASE = 'https://raw.githubusercontent.com/jordanfuzz/blog/master/photos/';

const { photo } = post.data;
const photoUrl = photo
  ? photo.startsWith('http') ? photo : `${PHOTOS_BASE}${photo}`
  : null;

const formatted = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card">
  <a href={`/posts/${post.id}`} class="post-card-thumb">
    {photoUrl
      ? <img src={photoUrl} alt="" aria-hidden="true" />
      : <div class="post-card-thumb-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
          </svg>
        </div>
    }
  </a>
  <div class="post-card-body">
    <div class="post-card-header">
      <h2><a href={`/posts/${post.id}`}>{post.data.title}</a></h2>
      <time datetime={post.data.date.toISOString()}>{formatted}</time>
    </div>
    {post.data.description && <p>{post.data.description}</p>}
  </div>
</article>

---
const pathname = Astro.url.pathname;
---

<nav>
  <div class="container">
    <a href="/" class="site-title">Jordan's Blog</a>
    <a href="/" aria-current={pathname === '/' ? 'page' : undefined}>Home</a>
    <a href="/archive" aria-current={pathname.startsWith('/archive') ? 'page' : undefined}>Archive</a>
    <a href="/about" aria-current={pathname.startsWith('/about') ? 'page' : undefined}>About</a>
  </div>
</nav>

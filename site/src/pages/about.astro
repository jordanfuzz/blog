---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Jordan's Blog" description="A little bit about Jordan.">
  <article class="post">
    <header class="post-header">
      <h1>About</h1>
    </header>
    <div class="post-body">
      <p>Hi, I'm Jordan. I'm a software developer based in the United States.</p>
      <p>I write here about whatever I'm currently into — games, travel, personal projects, and the occasional reflection. Posts are sporadic but genuine.</p>
      <p>You can find the source for this blog on <a href="https://github.com/jordanschalm/blog">GitHub</a>.</p>
    </div>
  </article>
</BaseLayout>
